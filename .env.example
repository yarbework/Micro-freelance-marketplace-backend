# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/micro_freelance?retryWrites=true&w=majority

# JWT Authentication (Dev 1)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# CORS / Frontend (Dev 5)
# Used by helmet/cors to know which frontend URL is allowed to make requests
CLIENT_URL=http://localhost:3000

# Email Configuration / Nodemailer (Dev 6)
# Used for sending application accepted/rejected emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
